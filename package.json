{
  "name": "envbeam",
  "version": "0.21.0",
  "description": "Pause your work on one machine, resume it whole on another: code, secrets, container, database, and Claude session — under the right account for each.",
  "type": "module",
  "bin": {
    "envbeam": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/core/config/schema.js"
  },
  "files": [
    "dist",
    "schema/envbeam.schema.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/write-build-info.mjs",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "envbeam": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "coverage": "vitest run --coverage",
    "schema:gen": "tsx scripts/gen-schema.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run schema:gen"
  },
  "keywords": [
    "cli",
    "devcontainer",
    "secrets",
    "doppler",
    "1password",
    "postgres",
    "claude-code",
    "dev-environment",
    "sync",
    "git"
  ],
  "author": "Alex Gvozden",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgvozden/envbeam.git"
  },
  "homepage": "https://github.com/alexgvozden/envbeam#readme",
  "bugs": {
    "url": "https://github.com/alexgvozden/envbeam/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
